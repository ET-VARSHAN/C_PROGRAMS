#include<stdio.h>
void sort(int a[], int n)
{
    int i, pos = 0;
    int max = a[0];
    for(i = 1; i < n; i++)
    {
        if(a[i] > max)
            max=a[i];
    }
    for(int val = 0; val <= max; val++)
    {
        for(i = pos; i < n; i++)
        {
            if(a[i] == val)
            {
                int temp = a[i];
                a[i] = a[pos];
                a[pos] = temp;
                pos++;
            }
        }
    }
}
int main()
{
    int a[] = {2,1,2,0,3,4};
    int n = 6;
    sort(a,n);
    for(int i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}